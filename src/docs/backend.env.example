# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==================== Server Configuration ====================
# Server port
PORT=5000

# Environment (development, staging, production)
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ==================== Razorpay Configuration ====================
# Get these from: https://razorpay.com/dashboard/settings/api-keys

# Razorpay API Key ID (Public Key)
RAZORPAY_KEY_ID=rzp_test_Shan2L8rKI7gfl

# Razorpay API Key Secret (Private Key - KEEP SECURE!)
RAZORPAY_KEY_SECRET=anPgytzInQor8S8vTKBv6dIx

# Razorpay Webhook Secret (Optional - for webhook verification)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ==================== Database Configuration (Optional) ====================
# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/agri-market

# Database Name
DB_NAME=agri-market

# ==================== Email Configuration (Optional) ====================
# SMTP Server
SMTP_HOST=smtp.gmail.com

# SMTP Port
SMTP_PORT=587

# SMTP Username (Email)
SMTP_USER=your_email@gmail.com

# SMTP Password (Use App Password if using Gmail)
SMTP_PASS=your_app_password_here

# Email From Address
MAIL_FROM=noreply@agrimarket.com

# ==================== JWT Configuration (Optional) ====================
# JWT Secret Key
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# JWT Token Expiry
JWT_EXPIRY=7d

# ==================== Third-party Services (Optional) ====================
# Twilio SMS (For OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid

TWILIO_AUTH_TOKEN=your_twilio_auth_token

TWILIO_PHONE_NUMBER=+1234567890

# AWS S3 (For Image Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key

AWS_SECRET_ACCESS_KEY=your_aws_secret_key

AWS_S3_BUCKET=agri-market-bucket

AWS_REGION=ap-south-1

# ==================== Logging ====================
# Log Level (debug, info, warn, error)
LOG_LEVEL=debug

# Enable Console Logs
ENABLE_CONSOLE_LOGS=true

# Log File Path (Optional)
LOG_FILE_PATH=logs/server.log
